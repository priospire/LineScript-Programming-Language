main() -> i64 do
  declare bad = gfx_new(0, 10)
  println(bad)

  declare g = gfx_new(4, 4)
  gfx_clear(g, -5, 300, 12)
  println(gfx_get(g, 0, 0))

  gfx_set(g, -1, 2, 1, 2, 3)
  gfx_set(g, 2, -1, 1, 2, 3)
  println(gfx_get(g, -1, 0))
  println(gfx_get(g, 4, 4))

  gfx_rect(g, 1, 1, 0, 2, 255, 255, 255, true)
  gfx_line(g, 0, 0, 0, 0, 5, 6, 7)
  println(gfx_get(g, 0, 0))

  println(gfx_save_ppm(g, "tests/artifacts/graphics_runtime.ppm"))
  gfx_free(g)
  println(gfx_save_ppm(g, "tests/artifacts/graphics_runtime2.ppm"))

  return 0
end
